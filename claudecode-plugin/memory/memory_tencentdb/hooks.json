{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --import tsx ${CLAUDE_PLUGIN_ROOT}/hooks/recall.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node --import tsx ${CLAUDE_PLUGIN_ROOT}/hooks/capture.ts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
