{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/absolute/path/to/TencentDB-Agent-Memory/node_modules/tsx/dist/cli.mjs\" \"/absolute/path/to/TencentDB-Agent-Memory/src/adapters/codex/cli.ts\"",
            "timeout": 5,
            "statusMessage": "Recalling TencentDB Agent Memory"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/absolute/path/to/TencentDB-Agent-Memory/node_modules/tsx/dist/cli.mjs\" \"/absolute/path/to/TencentDB-Agent-Memory/src/adapters/codex/cli.ts\"",
            "timeout": 5,
            "statusMessage": "Capturing TencentDB Agent Memory"
          }
        ]
      }
    ]
  }
}