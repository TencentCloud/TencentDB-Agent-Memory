{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory-tencentdb": {
      "type": "local",
      "command": [
        "node",
        "./bin/memory-tencentdb-mcp.mjs"
      ],
      "env": {
        "MEMORY_TENCENTDB_GATEWAY_URL": "http://127.0.0.1:8420",
        "MEMORY_TENCENTDB_GATEWAY_API_KEY": "${env:MEMORY_TENCENTDB_GATEWAY_API_KEY}"
      }
    }
  },
  "tools": {
    "memory-tencentdb": "./.opencode/tools/memory-tencentdb.ts"
  },
  "plugins": [
    "./.opencode/plugins/memory-tencentdb.ts"
  ]
}

