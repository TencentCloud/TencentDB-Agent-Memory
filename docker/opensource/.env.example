# Required. OpenAI-compatible LLM API key used by Hermes and the TDAI Gateway.
MODEL_API_KEY=your-api-key

# Defaults target Tencent Cloud LKE DeepSeek-V3.2. Override for another
# OpenAI-compatible endpoint.
MODEL_BASE_URL=https://api.lkeap.cloud.tencent.com/v1
MODEL_NAME=deepseek-v3.2
MODEL_PROVIDER=custom

# Host port exposed by docker compose. The Gateway still listens on 8420 inside
# the container.
TDAI_GATEWAY_PORT=8420

# Optional. Set this before exposing the Gateway beyond localhost; clients must
# send Authorization: Bearer <same-value>.
TDAI_GATEWAY_API_KEY=

# Optional. Comma-separated browser origins allowed to call the Gateway.
# Leave empty to emit no CORS headers.
TDAI_CORS_ORIGINS=
