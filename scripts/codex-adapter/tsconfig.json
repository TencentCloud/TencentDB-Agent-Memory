{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "codex-adapter.ts",
    "../../src/adapters/gateway-client/index.ts",
    "../../src/gateway/types.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
